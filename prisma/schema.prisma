generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// 核心模型：创作者
// ============================================
model Creator {
  id          String  @id @default(cuid())
  username    String  @unique
  displayName String
  avatar      String?
  bio         String?

  // 粉丝数据
  followers Int @default(0)
  following Int @default(0)
  likes     Int @default(0)

  // 账号信息
  tiktokId   String? @unique
  niche      String? // 领域分类
  country    String  @default("US")
  isVerified Boolean @default(false)

  // 综合评分（每日更新）
  accountScore   Float @default(0) // 账号价值总分
  engagementRate Float @default(0) // 平均互动率
  growthVelocity Float @default(0) // 成长速度

  // 元数据
  lastAnalyzed DateTime?
  updatedAt    DateTime  @updatedAt
  createdAt    DateTime  @default(now())

  // 关系
  videos         Video[]
  dailySnapshots CreatorDailySnapshot[]

  @@index([username])
  @@index([niche])
  @@index([country])
  @@index([accountScore])
  @@index([growthVelocity])
}

// ============================================
// 核心模型：视频
// ============================================
model Video {
  id        String  @id @default(cuid())
  tiktokId  String? @unique
  url       String?
  thumbnail String?
  caption   String? // 视频文案

  // 核心指标
  views    BigInt @default(0)
  likes    BigInt @default(0)
  comments BigInt @default(0)
  shares   BigInt @default(0)

  // 计算指标
  engagementRate Float @default(0) // 互动率
  shareRate      Float @default(0) // 分享率

  // 潜力评分（核心功能）
  viralScore  Float   @default(0) // 爆款潜力分 (0-100)
  isPotential Boolean @default(false) // 是否潜力视频
  isViral     Boolean @default(false) // 是否已爆

  // 增速指标（用于预测）
  viewVelocity       Float @default(0) // 播放量增速
  engagementVelocity Float @default(0) // 互动增速

  // 时间
  publishedAt DateTime
  scrapedAt   DateTime @default(now())

  // 关系
  creatorId String?
  creator   Creator? @relation(fields: [creatorId], references: [id])
  trendId   String?

  hashtags       VideoHashtag[]
  dailySnapshots VideoDailySnapshot[]
  VideoTrend     VideoTrend[]

  @@index([creatorId])
  @@index([trendId])
  @@index([viralScore])
  @@index([isPotential])
  @@index([publishedAt])
  @@index([scrapedAt])
}

// ============================================
// 核心模型：趋势（音乐/话题/挑战）
// ============================================
model Trend {
  id          String    @id @default(cuid())
  slug        String    @unique
  title       String
  name        String
  type        TrendType // MUSIC, HASHTAG, CHALLENGE
  description String?
  thumbnail   String?
  category    String?
  country     String    @default("US")

  // 趋势指标
  growthRate Float @default(0)
  velocity   Float @default(0) // 上升速度
  saturation Float @default(0) // 饱和度 (0-100)
  volume     Int   @default(0) // 总视频数
  views      String @default("0")
  creators   Int    @default(0)
  avgViews   String @default("0")

  // 预测
  viralScore    Float     @default(0)
  isRising      Boolean   @default(false)
  predictedPeak DateTime? // 预测峰值时间

  // 时间
  publishedAt   DateTime  @default(now())
  trendingSince DateTime?
  updatedAt     DateTime  @updatedAt

  // 关系
  videos       VideoTrend[]
  VideoHashtag VideoHashtag[]

  @@unique([name, type])
  @@index([type])
  @@index([viralScore])
  @@index([isRising])
  @@index([slug])
}

// Hashtag model for separate hashtag tracking
model Hashtag {
  id        String   @id @default(cuid())
  name      String   @unique
  views     String   @default("0")
  videos    Int      @default(0)
  country   String   @default("US")
  scrapedAt DateTime @default(now())

  @@index([name])
  @@index([views])
}

// ============================================
// 每日快照：追踪历史数据
// ============================================
model CreatorDailySnapshot {
  id        String  @id @default(cuid())
  creatorId String
  creator   Creator @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  // 当日数据
  followers      Int
  following      Int
  likes          Int
  engagementRate Float

  // 成长指标
  followerGrowth Float @default(0) // 粉丝增长率
  trendScore     Float @default(0)

  collectedAt DateTime @default(now())

  @@index([creatorId])
  @@index([collectedAt])
}

model VideoDailySnapshot {
  id      String @id @default(cuid())
  videoId String
  video   Video  @relation(fields: [videoId], references: [id], onDelete: Cascade)

  // 当日数据
  views    BigInt
  likes    BigInt
  comments BigInt
  shares   BigInt

  // 增长指标
  viewsGrowth    Float @default(0)
  likesGrowth    Float @default(0)
  engagementRate Float
  viralScore     Float

  collectedAt DateTime @default(now())

  @@index([videoId])
  @@index([collectedAt])
}

// ============================================
// 关联表
// ============================================
model VideoHashtag {
  id        String @id @default(cuid())
  videoId   String
  hashtagId String
  video     Video  @relation(fields: [videoId], references: [id], onDelete: Cascade)
  hashtag   Trend  @relation(fields: [hashtagId], references: [id], onDelete: Cascade)

  @@index([videoId])
  @@index([hashtagId])
}

model VideoTrend {
  id      String @id @default(cuid())
  videoId String
  trendId String
  video   Video  @relation(fields: [videoId], references: [id], onDelete: Cascade)
  trend   Trend  @relation(fields: [trendId], references: [id], onDelete: Cascade)

  @@index([videoId])
  @@index([trendId])
}

// ============================================
// 用户系统
// ============================================
model User {
  id           String @id @default(cuid())
  email        String @unique
  username     String @unique
  passwordHash String

  // 用户追踪的创作者
  trackedCreators String[] // 存储creator usernames

  // 订阅
  plan Plan @default(FREE)

  // 会话
  sessions Session[]

  // 邮箱验证
  emailVerifications EmailVerification[]

  // 元数据
  emailVerified Boolean   @default(false)
  lastLogin     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

// ============================================
// 枚举类型
// ============================================
enum TrendType {
  MUSIC
  HASHTAG
  CHALLENGE
  SOUND
}

enum Plan {
  FREE
  PRO
  ENTERPRISE
}

// ============================================
// 分析限制追踪
// ============================================
model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([token])
}

model EmailVerification {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  token      String    @unique
  expiresAt  DateTime
  verifiedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([userId])
  @@index([token])
}

model DailyAnalyzeLimit {
  id        String @id @default(cuid())
  userId    String?
  ipAddress String?
  date      String // YYYY-MM-DD format
  count     Int    @default(0)

  @@unique([userId, date])
  @@unique([ipAddress, date])
  @@index([date])
}

model AnalyzeTracking {
  id          String   @id @default(cuid())
  userId      String?
  fingerprint String?
  ipAddress   String?
  type        String   @default("video") // video, creator, hashtag
  targetId    String?
  targetUrl   String?
  data        Json?
  isGuest     Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([ipAddress])
  @@index([createdAt])
}

// ============================================
// 日志记录
// ============================================
model ScrapeLog {
  id        String   @id @default(cuid())
  type      String // scrape类型
  status    String // success/error
  count     Int      @default(0)
  error     String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([type])
  @@index([createdAt])
}
